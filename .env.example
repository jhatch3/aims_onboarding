# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/vendar"

# Redis connection string (optional — dashboard caching degrades gracefully without it)
REDIS_URL="redis://localhost:6379"

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Mapbox public token (optional — map page shows fallback without it)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Base URL for internal API calls in server components
NEXT_PUBLIC_BASE_URL="http://localhost:3000"